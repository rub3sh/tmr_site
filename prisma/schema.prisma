generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  STUDENT
  ADMIN
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
}

enum TaxMode {
  INCLUSIVE
  EXCLUSIVE
}

enum CourseStatus {
  DRAFT
  PUBLISHED
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum AttachmentType {
  PDF
  LINK
  TOOL
  NOTE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum GiveawayStatus {
  UPCOMING
  ACTIVE
  ENDED
}

enum IndicatorAccessPeriod {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum IndicatorTier {
  CORE
  SMT
  SUITE
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum EventType {
  LIVE_SESSION
  ECONOMIC_NEWS
  TRADE_BREAKDOWN
  PERSONAL
}

// ─── User ────────────────────────────────────────────────

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  name             String?
  passwordHash     String?            @map("password_hash")
  image            String?
  role             Role               @default(STUDENT)
  autoGenerated    Boolean            @default(false) @map("auto_generated")

  // Discord OAuth fields
  discordId        String?            @unique @map("discord_id")
  discordUsername  String?            @map("discord_username")
  discordAvatar    String?            @map("discord_avatar")

  // Verification
  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")
  studentId          String?           @unique @map("student_id")

  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  subscriptions    Subscription[]
  purchases        Purchase[]
  videoProgress    VideoProgress[]
  leaderboardEntries LeaderboardEntry[]
  giveawayEntries  GiveawayEntry[]
  discordLinks        DiscordLink[]
  calendarEvents      CalendarEvent[]    @relation("UserEvents")
  indicatorPurchases  IndicatorPurchase[]

  @@map("users")
}

// ─── Plans & Subscriptions ───────────────────────────────

model Plan {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  description   String?
  priceMonthly  Int             @map("price_monthly")
  priceYearly   Int             @map("price_yearly")
  currency      String          @default("INR")
  features      String[]
  isActive      Boolean         @default(true) @map("is_active")
  sortOrder     Int             @default(0) @map("sort_order")
  discordRoleId String?         @map("discord_role_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  planCourses   PlanCourse[]
  subscriptions Subscription[]

  @@map("plans")
}

model PlanCourse {
  id        String   @id @default(cuid())
  planId    String   @map("plan_id")
  courseId   String   @map("course_id")

  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([planId, courseId])
  @@map("plan_courses")
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @map("user_id")
  planId             String             @map("plan_id")
  billingCycle       BillingCycle       @default(MONTHLY) @map("billing_cycle")
  status             SubscriptionStatus @default(ACTIVE)
  razorpaySubId      String?            @unique @map("razorpay_sub_id")
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user               User               @relation(fields: [userId], references: [id])
  plan               Plan               @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

// ─── Courses (3-level hierarchy) ─────────────────────────

model Course {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  description     String
  shortDesc       String          @map("short_desc")
  thumbnailUrl    String          @map("thumbnail_url")
  previewVideoId  String?         @map("preview_video_id")
  priceInPaise    Int             @map("price_in_paise")
  currency        String          @default("INR")
  taxMode         TaxMode         @default(INCLUSIVE) @map("tax_mode")
  taxPercent      Float           @default(18) @map("tax_percent")
  difficulty      DifficultyLevel @default(BEGINNER)
  status          CourseStatus    @default(DRAFT)
  isPublished     Boolean         @default(false) @map("is_published")
  category        String?
  totalLessons    Int             @default(0) @map("total_lessons")
  totalVideos     Int             @default(0) @map("total_videos")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  lessons         Lesson[]
  purchases       Purchase[]
  planCourses     PlanCourse[]

  @@map("courses")
}

model Lesson {
  id          String       @id @default(cuid())
  courseId    String       @map("course_id")
  title       String
  description String?
  sortOrder   Int          @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  videos      Video[]
  attachments Attachment[]

  @@unique([courseId, sortOrder])
  @@map("lessons")
}

model Video {
  id           String         @id @default(cuid())
  lessonId     String         @map("lesson_id")
  title        String
  videoUrl     String         @map("video_url")
  vdoCipherId  String?        @map("vdocipher_id")
  durationSec  Int            @default(0) @map("duration_sec")
  sortOrder    Int            @map("sort_order")
  isFree       Boolean        @default(false) @map("is_free")
  isPreview    Boolean        @default(false) @map("is_preview")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  lesson       Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  progress     VideoProgress[]

  @@unique([lessonId, sortOrder])
  @@map("videos")
}

model Attachment {
  id        String         @id @default(cuid())
  lessonId  String         @map("lesson_id")
  type      AttachmentType
  title     String
  url       String
  fileSize  Int?           @map("file_size")
  createdAt DateTime       @default(now()) @map("created_at")

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

// ─── Progress Tracking (per video) ───────────────────────

model VideoProgress {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  videoId         String   @map("video_id")
  watchedSec      Int      @default(0) @map("watched_sec")
  totalSec        Int      @default(0) @map("total_sec")
  completed       Boolean  @default(false)
  lastPositionSec Int      @default(0) @map("last_position_sec")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id])
  video           Video    @relation(fields: [videoId], references: [id])

  @@unique([userId, videoId])
  @@map("video_progress")
}

// ─── Purchases (legacy direct course purchase) ──────────

model Purchase {
  id                 String         @id @default(cuid())
  userId             String         @map("user_id")
  courseId            String         @map("course_id")
  razorpayOrderId    String         @unique @map("razorpay_order_id")
  razorpayPaymentId  String?        @map("razorpay_payment_id")
  razorpaySignature  String?        @map("razorpay_signature")
  amountInPaise      Int            @map("amount_in_paise")
  currency           String         @default("INR")
  status             PurchaseStatus @default(PENDING)
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  user               User           @relation(fields: [userId], references: [id])
  course             Course         @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@map("purchases")
}

// ─── Leaderboard ─────────────────────────────────────────

model LeaderboardEntry {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  score           Float    @default(0)
  profitPercent   Float    @default(0) @map("profit_percent")
  consistency     Float    @default(0)
  completionScore Float    @default(0) @map("completion_score")
  weekOf          DateTime @map("week_of")
  createdAt       DateTime @default(now()) @map("created_at")

  user            User     @relation(fields: [userId], references: [id])

  @@unique([userId, weekOf])
  @@index([score(sort: Desc)])
  @@map("leaderboard_entries")
}

// ─── Calendar Events ─────────────────────────────────────

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  eventType   EventType @map("event_type")
  startTime   DateTime  @map("start_time")
  endTime     DateTime? @map("end_time")
  isPublic    Boolean   @default(true) @map("is_public")
  createdById String?   @map("created_by_id")
  notionId    String?   @map("notion_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  createdBy   User?     @relation("UserEvents", fields: [createdById], references: [id])

  @@map("calendar_events")
}

// ─── Giveaways ───────────────────────────────────────────

model Giveaway {
  id          String         @id @default(cuid())
  title       String
  description String
  prize       String
  rules       String[]
  imageUrl    String?        @map("image_url")
  status      GiveawayStatus @default(UPCOMING)
  maxEntries  Int?           @map("max_entries")
  startsAt    DateTime       @map("starts_at")
  endsAt      DateTime       @map("ends_at")
  winnerId    String?        @map("winner_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  entries     GiveawayEntry[]

  @@map("giveaways")
}

model GiveawayEntry {
  id          String   @id @default(cuid())
  giveawayId  String   @map("giveaway_id")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  giveaway    Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@unique([giveawayId, userId])
  @@map("giveaway_entries")
}

// ─── Discord Integration ─────────────────────────────────

model DiscordLink {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  inviteCode String   @unique @map("invite_code")
  used       Boolean  @default(false)
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id])

  @@map("discord_links")
}

// ─── Indicator Tier Pricing ──────────────────────────────

model IndicatorTierPricing {
  id          String        @id @default(cuid())
  tier        IndicatorTier @unique
  label       String
  description String        @default("")
  monthly     Int           @default(0)
  quarterly   Int           @default(0)
  annual      Int           @default(0)
  features    String[]      @default([])
  isActive    Boolean       @default(true) @map("is_active")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("indicator_tier_pricing")
}

// ─── Indicators ──────────────────────────────────────────

model Indicator {
  id                  String        @id @default(cuid())
  name                String
  slug                String        @unique
  description         String
  script              String?
  strategy            String?
  imageUrl            String?       @map("image_url")
  isPublic            Boolean       @default(false) @map("is_public")
  planIds             String[]      @map("plan_ids")
  tradingViewScriptId String?       @map("trading_view_script_id")
  tier                IndicatorTier @default(SUITE)
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  @@map("indicators")
}

model IndicatorPurchase {
  id                  String                @id @default(cuid())
  userId              String                @map("user_id")
  tier                IndicatorTier         @default(SUITE)
  tradingViewUsername String                @map("trading_view_username")
  accessPeriod        IndicatorAccessPeriod @map("access_period")
  razorpayOrderId     String                @unique @map("razorpay_order_id")
  razorpayPaymentId   String?               @map("razorpay_payment_id")
  razorpaySignature   String?               @map("razorpay_signature")
  amountInPaise       Int                   @map("amount_in_paise")
  currency            String                @default("INR")
  status              PurchaseStatus        @default(PENDING)
  tvAccessGranted     Boolean               @default(false) @map("tv_access_granted")
  accessExpiresAt     DateTime?             @map("access_expires_at")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  user                User                  @relation(fields: [userId], references: [id])

  @@map("indicator_purchases")
}

// ─── Blog Categories ─────────────────────────────────────

model BlogCategory {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  sortOrder Int        @default(0) @map("sort_order")
  createdAt DateTime   @default(now()) @map("created_at")

  posts     BlogPost[]

  @@map("blog_categories")
}

// ─── Blog Posts (Market Education) ───────────────────────

model BlogPost {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  excerpt      String
  content      String
  categoryId   String       @map("category_id")
  thumbnailUrl String?      @map("thumbnail_url")
  readTime     String?      @map("read_time")
  format       String?
  isPublished  Boolean      @default(false) @map("is_published")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  category     BlogCategory @relation(fields: [categoryId], references: [id])

  @@map("blog_posts")
}

// ─── Coupons ─────────────────────────────────────────────

model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique
  discountPercent Int    @map("discount_percent")
  maxUses       Int?     @map("max_uses")
  usedCount     Int      @default(0) @map("used_count")
  isActive      Boolean  @default(true) @map("is_active")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("coupons")
}
